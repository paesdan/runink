package contracts

import (
    "encoding/json"
    "errors"
    "io"
    "strings"
    "time"
)

var (
    ContractVersion      = "1.1.0"
    ContractSchemaHash   = "TBD"
    ComplianceLevel      = "gold"
    DefaultMaskingPolicy = "tokenize"
)

type CSARecord struct {
    DocumentID     string    `json:"document_id" validate:"required" mask:"none"`
    Counterparty   string    `json:"counterparty" validate:"required" mask:"none"`
    Jurisdiction   string    `json:"jurisdiction" validate:"required" mask:"none"`
    ClauseCount    int       `json:"clause_count" validate:"required" mask:"none"`
    RiskScore      float64   `json:"risk_score,omitempty" mask:"none"`
    LLMSummary     string    `json:"llm_summary,omitempty" mask:"none"`
    LegalReviewer  string    `json:"legal_reviewer,omitempty" mask:"redact"`
    ReviewDate     time.Time `json:"review_date,omitempty" mask:"none"`
    ContractVersion string   `json:"contract_version,omitempty" mask:"none"`
}

type EnrichedCSARecord struct {
    CSARecord
}

var Steps = []string{
    "ParseCSADocuments",
    "EnrichWithLLM",
    "ValidateClauses",
    "ApplyReviewerMasking",
    "TagComplianceTier",
    "DetectContractDrift",
    "EmitValidCSAs",
}

func ParseCSADocuments(r io.Reader, w io.Writer) error {
    decoder := json.NewDecoder(r)
    encoder := json.NewEncoder(w)
    for decoder.More() {
        var c CSARecord
        if err := decoder.Decode(&c); err != nil {
            return err
        }
        encoder.Encode(c)
    }
    return nil
}

func EnrichWithLLM(r io.Reader, w io.Writer) error {
    decoder := json.NewDecoder(r)
    encoder := json.NewEncoder(w)
    for decoder.More() {
        var c CSARecord
        if err := decoder.Decode(&c); err != nil {
            return err
        }
        // Mock LLM summary for now
        c.LLMSummary = "CSA document discusses margin terms and collateral obligations."
        encoder.Encode(c)
    }
    return nil
}

func ValidateClauses(r io.Reader, w io.Writer) error {
    decoder := json.NewDecoder(r)
    encoder := json.NewEncoder(w)
    for decoder.More() {
        var c CSARecord
        if err := decoder.Decode(&c); err != nil {
            return err
        }
        if c.ClauseCount < 5 {
            continue // Consider too short for standard compliance
        }
        encoder.Encode(c)
    }
    return nil
}

func ApplyReviewerMasking(r io.Reader, w io.Writer) error {
    decoder := json.NewDecoder(r)
    encoder := json.NewEncoder(w)
    for decoder.More() {
        var c CSARecord
        if err := decoder.Decode(&c); err != nil {
            return err
        }
        if c.LegalReviewer != "" {
            c.LegalReviewer = applyMask(c.LegalReviewer)
        }
        encoder.Encode(c)
    }
    return nil
}

func TagComplianceTier(r io.Reader, w io.Writer) error {
    decoder := json.NewDecoder(r)
    encoder := json.NewEncoder(w)
    for decoder.More() {
        var c CSARecord
        if err := decoder.Decode(&c); err != nil {
            return err
        }
        if strings.Contains(c.LLMSummary, "margin") {
            c.RiskScore = 0.9
        }
        encoder.Encode(c)
    }
    return nil
}

func DetectContractDrift(r io.Reader, w io.Writer) error {
    decoder := json.NewDecoder(r)
    encoder := json.NewEncoder(w)
    for decoder.More() {
        var c CSARecord
        if err := decoder.Decode(&c); err != nil {
            return err
        }
        if c.ContractVersion != ContractVersion {
            continue
        }
        encoder.Encode(c)
    }
    return nil
}

func EmitValidCSAs(r io.Reader, w io.Writer) error {
    decoder := json.NewDecoder(r)
    encoder := json.NewEncoder(w)
    for decoder.More() {
        var c CSARecord
        if err := decoder.Decode(&c); err != nil {
            return err
        }
        encoder.Encode(c)
    }
    return nil
}

func applyMask(value string) string {
    if value == "" {
        return value
    }
    return "token-" + value[:3]
}
